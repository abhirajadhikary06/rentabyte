# RentAByte – Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Polygon RPC ──────────────────────────────────────────────────────────────
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology

# ── Smart Contract (set after: npx hardhat run hardhat-scripts/deploy.js) ────
CONTRACT_ADDRESS=

# ── Fallback platform wallet (if no contract deployed) ───────────────────────
PLATFORM_WALLET=

# ── Storage Pricing ───────────────────────────────────────────────────────────
# How many POL tokens per 100 MB (must match Solidity constructor arg)
POL_PER_100MB=0.01

# ── File Encryption ───────────────────────────────────────────────────────────
# Run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Paste the result here. Keep this SAFE — losing it means losing all files.
FERNET_KEY=

# ── Chunk Size ────────────────────────────────────────────────────────────────
CHUNK_SIZE_MB=5

# ── Database URL (Neon PostgreSQL) ───────────────────────────────────────────
NEONDB_DATABASE_URL=